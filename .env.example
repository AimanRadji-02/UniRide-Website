#
# UniRide environment variables (copy to `.env` and fill values)
#
# IMPORTANT:
# - Do NOT commit `.env` (it is gitignored)
# - Restart the Flask app after changes
#

# Google Maps JavaScript API key (enable Maps JavaScript API + Places API in Google Cloud)
GOOGLE_MAPS_API_KEY=PASTE_YOUR_KEY_HERE

# Optional (defaults are fine for local dev)
# SECRET_KEY=change-me
# FLASK_ENV=development
# DEBUG=true
